{
  "name": "rizkyfeb-portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build --no-lint",
    "dev": "next dev",
    "format": "prettier . --write --cache",
    "lint": "next lint",
    "start": "next start",
    "predeploy": "pnpm run build",
    "deploy": "pnpm run predeploy && gh-pages --dist out --branch gh-pages --dotfiles --message 'Deploy to GitHub Pages [skip ci]'",
